<Window x:Class="TurboAuctionWPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Turbo Auction Dashboard" Height="650" Width="1100">
    <Grid Background="#F4F6F8">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="280"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#1F2937" Padding="15">
            <StackPanel>
                <TextBlock Text="Turbo Auction" Foreground="White" FontSize="22" FontWeight="Bold" Margin="0,0,0,20"/>
                <TextBlock x:Name="UserStatusText" Text="User: Zunaina" Foreground="White" Margin="0,0,0,5"/>
                <TextBox x:Name="UsernameBox" Height="25" Margin="0,0,0,10" Text="Zunaina"/>
                <Button Content="Login" Click="Login_Click" Height="30" Margin="0,0,0,20"/>
                <TextBlock Text="Categories" Foreground="White" FontSize="16" Margin="0,0,0,10"/>
                <Button Content="Supercars" Margin="0,2"/>
                <Button Content="Luxury" Margin="0,2"/>
            </StackPanel>
        </Border>

        <Border Grid.Column="1" Background="White" Margin="10" CornerRadius="10" Padding="20">
            <StackPanel HorizontalAlignment="Center">
                <Image x:Name="CarImage" Width="400" Height="250" Stretch="Uniform"/>
                <TextBlock x:Name="CarTitleText" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,10"/>
                <TextBlock x:Name="CategoryText" FontSize="14" Foreground="Gray" HorizontalAlignment="Center"/>
                <TextBlock x:Name="CurrentPriceText" FontSize="30" FontWeight="Bold" Foreground="Green" HorizontalAlignment="Center" Margin="0,15"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button Content="Previous" Click="PreviousCar_Click" Width="100" Margin="5"/>
                    <Button Content="Next" Click="NextCar_Click" Width="100" Margin="5"/>
                    <Button Content="Bid Now (+$1000)" Click="PlaceBid_Click" Width="150" FontWeight="Bold" Background="Gold" Margin="5"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <Border Grid.Column="2" Background="#111827" Padding="15">
            <StackPanel>
                <TextBlock Text="Master Timer" Foreground="White" FontSize="18" Margin="0,0,0,10"/>
                <TextBlock x:Name="TimerText" Text="Time Left: 00:30" Foreground="White" FontSize="25" HorizontalAlignment="Center"/>
                <ProgressBar x:Name="TimerBar" Height="15" Maximum="30" Value="30" Margin="0,10,0,20"/>
                <TextBlock Text="Bid History" Foreground="White" Margin="0,0,0,5"/>
                <ListBox x:Name="BidHistoryList" Height="150" Margin="0,0,0,20"/>
                <TextBlock Text="Notifications" Foreground="White" Margin="0,0,0,5"/>
                <ListBox x:Name="NotificationList" Height="120"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>