<Window x:Class="TurboAuctionWPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Turbo Auction Dashboard"
        Height="650"
        Width="1100">

    <Grid Background="#F4F6F8">

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="280"/>
        </Grid.ColumnDefinitions>

        <!-- LEFT SIDEBAR -->
        <Border Grid.Column="0"
                Background="#1F2937"
                Padding="18">

            <StackPanel>

                <TextBlock Text="Turbo Auction"
                           Foreground="White"
                           FontSize="22"
                           FontWeight="Bold"
                           Margin="0,0,0,25"/>

                <TextBlock x:Name="UserStatusText"
                           Text="User: Areeba"
                           Foreground="White"
                           FontSize="14"
                           Margin="0,0,0,8"/>

                <TextBox x:Name="UsernameBox"
                         Height="30"
                         Margin="0,0,0,8"
                         Text="Areeba"/>

                <Button Content="Login"
                        Height="32"
                        Margin="0,0,0,15"
                        Click="Login_Click"/>

                <StackPanel Orientation="Horizontal"
                            Margin="0,0,0,25">
                    <Ellipse Width="12"
                             Height="12"
                             Fill="LimeGreen"
                             Margin="0,0,8,0"/>
                    <TextBlock Text="Connected"
                               Foreground="LightGreen"
                               FontSize="14"/>
                </StackPanel>

                <TextBlock Text="Categories"
                           Foreground="White"
                           FontSize="16"
                           FontWeight="Bold"
                           Margin="0,0,0,10"/>

                <Button Content="Supercars"
                        Height="35"
                        Margin="0,5,0,5"/>

                <Button Content="Luxury Sedans"
                        Height="35"
                        Margin="0,5,0,5"/>

                <Button Content="SUV"
                        Height="35"
                        Margin="0,5,0,5"/>

                <Button Content="Electric"
                        Height="35"
                        Margin="0,5,0,5"/>

            </StackPanel>
        </Border>

        <!-- MAIN AUCTION AREA -->
        <Border Grid.Column="1"
                Background="White"
                Margin="18"
                Padding="25"
                CornerRadius="12">

            <StackPanel HorizontalAlignment="Center"
                        VerticalAlignment="Center">

                <TextBlock Text="Live Car Auction"
                           FontSize="26"
                           FontWeight="Bold"
                           Margin="0,0,0,15"
                           HorizontalAlignment="Center"/>

                <Border Background="#F9FAFB"
                        BorderBrush="#D1D5DB"
                        BorderThickness="1"
                        CornerRadius="12"
                        Padding="18">

                    <StackPanel HorizontalAlignment="Center">

                        <Grid Margin="0,0,0,10">

                            <Image x:Name="CarImage"
                                   Width="430"
                                   Height="260"
                                   Stretch="Uniform"/>

                            <TextBlock x:Name="LiveBadge"
                                       Text="LIVE"
                                       Foreground="White"
                                       Background="Red"
                                       FontWeight="Bold"
                                       Padding="8,4"
                                       HorizontalAlignment="Left"
                                       VerticalAlignment="Top"
                                       Margin="10"/>

                        </Grid>

                        <TextBlock x:Name="CarTitleText"
                                   FontSize="22"
                                   FontWeight="Bold"
                                   Margin="0,10,0,0"
                                   HorizontalAlignment="Center"/>

                        <TextBlock x:Name="CategoryText"
                                   FontSize="15"
                                   Foreground="Gray"
                                   Margin="0,5,0,0"
                                   HorizontalAlignment="Center"/>

                        <TextBlock x:Name="CurrentPriceText"
                                   FontSize="28"
                                   FontWeight="Bold"
                                   Foreground="Green"
                                   Margin="0,10,0,0"
                                   HorizontalAlignment="Center"/>

                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Center"
                                    Margin="0,20,0,0">

                            <Button Content="Previous Car"
                                    Width="130"
                                    Height="35"
                                    Margin="8"
                                    Click="PreviousCar_Click"/>

                            <Button Content="Next Car"
                                    Width="130"
                                    Height="35"
                                    Margin="8"
                                    Click="NextCar_Click"/>

                            <Button Content="Bid Now (+$1000)"
                                    Width="170"
                                    Height="35"
                                    Margin="8"
                                    FontWeight="Bold"
                                    Click="PlaceBid_Click"/>

                        </StackPanel>

                    </StackPanel>
                </Border>

            </StackPanel>
        </Border>

        <!-- RIGHT ACTION PANEL -->
        <Border Grid.Column="2"
                Background="#111827"
                Padding="18">

            <StackPanel>

                <TextBlock Text="Master Timer"
                           Foreground="White"
                           FontSize="20"
                           FontWeight="Bold"
                           Margin="0,0,0,10"/>

                <Border Background="#1F2937"
                        CornerRadius="8"
                        Padding="15"
                        Margin="0,0,0,20">

                    <StackPanel>

                        <TextBlock x:Name="TimerText"
                                   FontSize="28"
                                   FontWeight="Bold"
                                   Foreground="White"
                                   HorizontalAlignment="Center"
                                   Text="Time Left: 00:30"/>

                        <ProgressBar x:Name="TimerBar"
                                     Width="220"
                                     Height="18"
                                     Margin="0,12,0,0"
                                     Maximum="30"
                                     Value="30"/>

                    </StackPanel>
                </Border>

                <TextBlock Text="Bid History"
                           Foreground="White"
                           FontSize="20"
                           FontWeight="Bold"
                           Margin="0,0,0,10"/>

                <ListBox x:Name="BidHistoryList"
                         Height="180"
                         Margin="0,0,0,20"/>

                <TextBlock Text="Notifications"
                           Foreground="White"
                           FontSize="20"
                           FontWeight="Bold"
                           Margin="0,0,0,10"/>

                <ListBox x:Name="NotificationList"
                         Height="130"/>

            </StackPanel>
        </Border>

    </Grid>
</Window>
