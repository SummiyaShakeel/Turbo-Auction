<Window x:Class="TurboAuctionWPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Turbo Auction" Height="450" Width="800">

    <Grid>
        <StackPanel HorizontalAlignment="Center"
                    VerticalAlignment="Center">

            <Image x:Name="CarImage"
                   Width="300"
                   Height="200"
                   Margin="0,10,0,10"
                   Stretch="Uniform"/>

            <TextBlock x:Name="CarTitleText"
                       FontSize="18"
                       Margin="0,10,0,0"
                       HorizontalAlignment="Center"/>

            <TextBlock x:Name="CurrentPriceText"
                       FontSize="20"
                       FontWeight="Bold"
                       Margin="0,5,0,0"
                       HorizontalAlignment="Center"/>

            <TextBlock x:Name="TimerText"
                       FontSize="16"
                       Margin="0,10,0,0"
                       HorizontalAlignment="Center"
                       Text="Time Left: 00:30"/>

            <ProgressBar x:Name="TimerBar"
                         Width="300"
                         Height="18"
                         Margin="0,8,0,0"
                         Maximum="30"
                         Value="30"/>

            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Center"
                        Margin="0,20,0,0">

                <Button Content="Previous Car"
                        Width="120"
                        Margin="10"
                        Click="PreviousCar_Click"/>

                <Button Content="Next Car"
                        Width="120"
                        Margin="10"
                        Click="NextCar_Click"/>
                <Button Content="Place Bid (+$1000)"
        Width="200"
        Margin="10"
        HorizontalAlignment="Center"
        Click="PlaceBid_Click"/>

            </StackPanel>

        </StackPanel>
    </Grid>

</Window>